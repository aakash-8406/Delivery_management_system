# Copy this file to .env and fill in values for local development.
# In CI/CD, these are injected by Jenkins credentials — never commit real values.

# AWS API Gateway base URL (no trailing slash)
VITE_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# Master key for internal API auth
VITE_MASTER_KEY=your-master-key-here
