pipeline {
  agent any

  environment {
    DOCKERHUB_USER   = "aakash985"   
    CUSTOMER_IMAGE   = "${DOCKERHUB_USER}/bitrush-customer"
    RESTAURANT_IMAGE = "${DOCKERHUB_USER}/smartqueue-restaurant"
    IMAGE_TAG        = "${BUILD_NUMBER}"
    K8S_NAMESPACE    = "smartqueue"
  }

  stages {

    // ── 1. Checkout ──────────────────────────────────────────────────────────
    stage('Checkout') {
      steps {
        checkout scm
        sh 'git log --oneline -1'
      }
    }

    // ── 2. Deploy Lambda ─────────────────────────────────────────────────────
    stage('Deploy Lambda') {
      steps {
        withCredentials([
          string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_ACCESS_KEY_ID'),
          string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
          string(credentialsId: 'AWS_REGION',            variable: 'AWS_DEFAULT_REGION')
        ]) {
          sh """
            # Create Users table if not exists
            aws dynamodb create-table \
              --table-name Users \
              --attribute-definitions AttributeName=email,AttributeType=S \
              --key-schema AttributeName=email,KeyType=HASH \
              --billing-mode PAY_PER_REQUEST \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true
            aws dynamodb wait table-exists --table-name Users --region \${AWS_DEFAULT_REGION} || true

            # Update Lambda env vars — register and login use USERS_TABLE + RESTAURANTS_TABLE
            aws lambda update-function-configuration \
              --function-name smartqueue-register \
              --environment "Variables={USERS_TABLE=Users,RESTAURANTS_TABLE=Restaurants,JWT_SECRET=smartqueue-secret}" \
              --region \${AWS_DEFAULT_REGION}
            aws lambda wait function-updated --function-name smartqueue-register --region \${AWS_DEFAULT_REGION}

            aws lambda update-function-configuration \
              --function-name smartqueue-login \
              --environment "Variables={USERS_TABLE=Users,RESTAURANTS_TABLE=Restaurants,JWT_SECRET=smartqueue-secret}" \
              --region \${AWS_DEFAULT_REGION}
            aws lambda wait function-updated --function-name smartqueue-login --region \${AWS_DEFAULT_REGION}

            # Deploy register
            cd deliver_management_system/infra/lambda/register
            zip -j register.zip index.mjs
            aws lambda update-function-code --function-name smartqueue-register --zip-file fileb://register.zip --region \${AWS_DEFAULT_REGION}
            rm register.zip

            # Deploy login
            cd ../login
            zip -j login.zip index.mjs
            aws lambda update-function-code --function-name smartqueue-login --zip-file fileb://login.zip --region \${AWS_DEFAULT_REGION}
            rm login.zip

            # Deploy getRestaurants
            cd ../getRestaurants
            zip -j getRestaurants.zip index.mjs
            aws lambda update-function-code --function-name smartqueue-getRestaurants --zip-file fileb://getRestaurants.zip --region \${AWS_DEFAULT_REGION}
            rm getRestaurants.zip

            # Create Customers table and deploy customer auth Lambdas
            aws dynamodb create-table \
              --table-name Customers \
              --attribute-definitions AttributeName=email,AttributeType=S \
              --key-schema AttributeName=email,KeyType=HASH \
              --billing-mode PAY_PER_REQUEST \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true
            aws dynamodb wait table-exists --table-name Customers --region \${AWS_DEFAULT_REGION} || true

            # Create customerRegister Lambda if not exists
            aws lambda create-function \
              --function-name smartqueue-customerRegister \
              --runtime nodejs20.x \
              --role arn:aws:iam::948976368048:role/smartqueue-lambda-exec-role \
              --handler index.handler \
              --zip-file fileb:///dev/null \
              --environment "Variables={CUSTOMERS_TABLE=Customers}" \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true

            # Create customerLogin Lambda if not exists
            aws lambda create-function \
              --function-name smartqueue-customerLogin \
              --runtime nodejs20.x \
              --role arn:aws:iam::948976368048:role/smartqueue-lambda-exec-role \
              --handler index.handler \
              --zip-file fileb:///dev/null \
              --environment "Variables={CUSTOMERS_TABLE=Customers}" \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true

            # Update env vars
            aws lambda update-function-configuration \
              --function-name smartqueue-customerRegister \
              --environment "Variables={CUSTOMERS_TABLE=Customers}" \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true
            aws lambda update-function-configuration \
              --function-name smartqueue-customerLogin \
              --environment "Variables={CUSTOMERS_TABLE=Customers}" \
              --region \${AWS_DEFAULT_REGION} 2>/dev/null || true

            # Deploy customerRegister code
            cd ../customerRegister
            zip -j customerRegister.zip index.mjs
            aws lambda update-function-code --function-name smartqueue-customerRegister --zip-file fileb://customerRegister.zip --region \${AWS_DEFAULT_REGION}
            rm customerRegister.zip

            # Deploy customerLogin code
            cd ../customerLogin
            zip -j customerLogin.zip index.mjs
            aws lambda update-function-code --function-name smartqueue-customerLogin --zip-file fileb://customerLogin.zip --region \${AWS_DEFAULT_REGION}
            rm customerLogin.zip

            # Add API Gateway permissions for old API (kkidytruee)
            aws lambda add-permission --function-name smartqueue-customerRegister --statement-id AllowOldAPICustomerRegister --action lambda:InvokeFunction --principal apigateway.amazonaws.com --source-arn "arn:aws:execute-api:\${AWS_DEFAULT_REGION}:948976368048:kkidytruee/*/*" --region \${AWS_DEFAULT_REGION} 2>/dev/null || true
            aws lambda add-permission --function-name smartqueue-customerLogin --statement-id AllowOldAPICustomerLogin --action lambda:InvokeFunction --principal apigateway.amazonaws.com --source-arn "arn:aws:execute-api:\${AWS_DEFAULT_REGION}:948976368048:kkidytruee/*/*" --region \${AWS_DEFAULT_REGION} 2>/dev/null || true

            # Add routes to old API Gateway
            CUSTOMER_REG_INT=\$(aws apigatewayv2 create-integration --api-id kkidytruee --integration-type AWS_PROXY --integration-uri arn:aws:apigateway:\${AWS_DEFAULT_REGION}:lambda:path/2015-03-31/functions/arn:aws:lambda:\${AWS_DEFAULT_REGION}:948976368048:function:smartqueue-customerRegister/invocations --payload-format-version 2.0 --region \${AWS_DEFAULT_REGION} --query IntegrationId --output text 2>/dev/null)
            aws apigatewayv2 create-route --api-id kkidytruee --route-key "POST /customerRegister" --target "integrations/\${CUSTOMER_REG_INT}" --region \${AWS_DEFAULT_REGION} 2>/dev/null || true

            CUSTOMER_LOGIN_INT=\$(aws apigatewayv2 create-integration --api-id kkidytruee --integration-type AWS_PROXY --integration-uri arn:aws:apigateway:\${AWS_DEFAULT_REGION}:lambda:path/2015-03-31/functions/arn:aws:lambda:\${AWS_DEFAULT_REGION}:948976368048:function:smartqueue-customerLogin/invocations --payload-format-version 2.0 --region \${AWS_DEFAULT_REGION} --query IntegrationId --output text 2>/dev/null)
            aws apigatewayv2 create-route --api-id kkidytruee --route-key "POST /customerLogin" --target "integrations/\${CUSTOMER_LOGIN_INT}" --region \${AWS_DEFAULT_REGION} 2>/dev/null || true
          """
        }
      }
    }

    // ── 3. Build — secrets injected from Jenkins Credentials ─────────────────
    stage('Build Images') {
      parallel {

        stage('customer-app') {
          steps {
            withCredentials([
              string(credentialsId: 'API_GATEWAY_URL', variable: 'API_URL'),
              string(credentialsId: 'MASTER_KEY',      variable: 'MKEY')
            ]) {
              sh """
                docker build \\
                  --build-arg VITE_API_URL=\${API_URL} \\
                  --build-arg VITE_MASTER_KEY=\${MKEY} \\
                  -t ${CUSTOMER_IMAGE}:${IMAGE_TAG} \\
                  -t ${CUSTOMER_IMAGE}:latest \\
                  ./deliver_management_system/customers-app
              """
            }
          }
        }

        stage('restaurant-app') {
          steps {
            withCredentials([
              string(credentialsId: 'API_GATEWAY_URL', variable: 'API_URL'),
              string(credentialsId: 'MASTER_KEY',      variable: 'MKEY')
            ]) {
              sh """
                docker build \\
                  --build-arg VITE_API_URL=\${API_URL} \\
                  --build-arg VITE_MASTER_KEY=\${MKEY} \\
                  -t ${RESTAURANT_IMAGE}:${IMAGE_TAG} \\
                  -t ${RESTAURANT_IMAGE}:latest \\
                  ./deliver_management_system/restaurant-app
              """
            }
          }
        }

      }
    }

    // ── 4. Push to DockerHub ─────────────────────────────────────────────────
    stage('Push to DockerHub') {
      steps {
        retry(3) {
          withCredentials([usernamePassword(
            credentialsId: 'dockerhub-credentials',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
          )]) {
            sh """
              echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
              docker push ${CUSTOMER_IMAGE}:${IMAGE_TAG}
              docker push ${CUSTOMER_IMAGE}:latest
              docker push ${RESTAURANT_IMAGE}:${IMAGE_TAG}
              docker push ${RESTAURANT_IMAGE}:latest
              docker logout
            """
          }
        }
      }
    }

    // ── 5. Deploy to Kubernetes ──────────────────────────────────────────────
    stage('Deploy to Kubernetes') {
      steps {
        sh """
          kubectl apply -f deliver_management_system/k8s/namespace.yaml

          sed 's|DOCKERHUB_USER|${DOCKERHUB_USER}|g; s|IMAGE_TAG|${IMAGE_TAG}|g' \\
            deliver_management_system/k8s/customer-app.yaml | kubectl apply -f -

          sed 's|DOCKERHUB_USER|${DOCKERHUB_USER}|g; s|IMAGE_TAG|${IMAGE_TAG}|g' \\
            deliver_management_system/k8s/restaurant-app.yaml | kubectl apply -f -
        """
      }
    }

    // ── 6. Verify rollout ────────────────────────────────────────────────────
    stage('Verify Rollout') {
      steps {
        sh """
          kubectl rollout status deployment/customer-app   -n ${K8S_NAMESPACE} --timeout=120s
          kubectl rollout status deployment/restaurant-app -n ${K8S_NAMESPACE} --timeout=120s
          kubectl get pods -n ${K8S_NAMESPACE}
          kubectl get svc  -n ${K8S_NAMESPACE}
        """
      }
    }

    // ── 7. Cleanup ───────────────────────────────────────────────────────────
    stage('Cleanup') {
      steps {
        sh "docker image prune -f || true"
      }
    }

  }

  post {
    success {
      sh """
        EC2_IP=\$(curl -s http://169.254.169.254/latest/meta-data/public-ipv4 2>/dev/null || echo 'YOUR_EC2_IP')
        echo "============================================"
        echo "✅  BUILD #${BUILD_NUMBER} DEPLOYED"
        echo "--------------------------------------------"
        echo "customer-app   → http://\${EC2_IP}:30174"
        echo "restaurant-app → http://\${EC2_IP}:30175"
        echo "============================================"
      """
    }
    failure {
      sh """
        echo "❌ Build failed — rolling back"
        kubectl rollout undo deployment/customer-app   -n ${K8S_NAMESPACE} || true
        kubectl rollout undo deployment/restaurant-app -n ${K8S_NAMESPACE} || true
      """
    }
  }
}
